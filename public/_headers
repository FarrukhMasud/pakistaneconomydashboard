# Cloudflare Pages cache rules.
# Keep the entry point and data files always-fresh so updated economic data
# (committed to git → auto-deployed) is picked up immediately. Hashed asset
# filenames change on every build, so they can be cached forever.

/index.html
  Cache-Control: no-store, must-revalidate

/data/*
  Cache-Control: no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
